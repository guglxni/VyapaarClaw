graph LR
    Start(["Input: Agent Payout Request"]) --> CheckPol{"1. Policy<br/>Valid?"}
    CheckPol -- Yes --> CheckDom{"2. Domain<br/>Allowed?"}
    CheckPol -- No --> R1["Reject (NO_POLICY)"]
    
    CheckDom -- Yes --> CheckTxn{"3. Under<br/>Txn Limit?"}
    CheckDom -- No --> R2["Reject (DOMAIN_BLOCKED)"]
    
    CheckTxn -- Yes --> CheckML{"4. Anomaly<br/>Score OK?"}
    CheckTxn -- No --> R3["Reject (LIMIT_EXCEEDED)"]
    
    CheckML -- Pass --> CheckRep{"5. Reputation<br/>Safe?"}
    CheckML -- Fail --> H1["Hold (ML_FLAGGED)"]
    
    CheckRep -- Yes --> CheckBud{"6. Budget<br/>Available?"}
    CheckRep -- No --> R4["Reject (RISK_HIGH)"]
    
    CheckBud -- Yes --> CheckAuto{"7. Auto<br/>Approve?"}
    CheckBud -- No --> R5["Reject (NO_FUNDS)"]
    
    CheckAuto -- Yes --> App["Approve Payout"]
    CheckAuto -- No --> H2["Hold (REQUIRE_L1)"]
    
    H1 --> M["Manual Review via Slack"]
    H2 --> M
    M -- Approve --> App
    M -- Deny --> R6["Reject (OVERRIDE)"]
